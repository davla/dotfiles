# Default applications settings
#
# {{@@ header() @@}}

{%@@ set browser_desktop = desktop_with_name(browser) @@%}
{%@@ set geany_desktop = desktop_with_name('geany') @@%}
{%@@ set mpv_desktop = desktop_with_name('mpv') @@%}
{%@@ set telegram_desktop = desktop_with_name('telegram') -@@%}

[Default Applications]
application/json={{@@ geany_desktop @@}}
application/octet-stream={{@@ browser_desktop @@}}
application/ogg={{@@ mpv_desktop @@}}
application/pdf={{@@ browser_desktop @@}}
application/vnd.oasis.opendocument.text=libreoffice-writer.desktop
application/x-extension-htm={{@@ geany_desktop @@}}
application/x-extension-html={{@@ geany_desktop @@}}
application/x-extension-shtml={{@@ geany_desktop @@}}
application/x-extension-xht={{@@ geany_desktop @@}}
application/x-extension-xhtml={{@@ geany_desktop @@}}
application/xhtml+xml={{@@ geany_desktop @@}}
audio/x-aac={{@@ mpv_desktop @@}}
audio/x-aiff={{@@ mpv_desktop @@}}
audio/x-flac={{@@ mpv_desktop @@}}
audio/x-it={{@@ mpv_desktop @@}}
audio/x-mod={{@@ mpv_desktop @@}}
audio/x-ms-asx={{@@ mpv_desktop @@}}
audio/x-ms-wma={{@@ mpv_desktop @@}}
audio/x-musepack={{@@ mpv_desktop @@}}
audio/x-ogg={{@@ mpv_desktop @@}}
audio/x-opus+ogg={{@@ mpv_desktop @@}}
audio/x-s3m={{@@ mpv_desktop @@}}
audio/x-speex+ogg={{@@ mpv_desktop @@}}
audio/x-tta={{@@ mpv_desktop @@}}
audio/x-wavpack={{@@ mpv_desktop @@}}
audio/x-xm={{@@ mpv_desktop @@}}
image/*={{@@ browser_desktop @@}}
image/gif={{@@ browser_desktop @@}}
image/jpeg={{@@ browser_desktop @@}}
image/png={{@@ browser_desktop @@}}
image/svg+xml-compressed={{@@ browser_desktop @@}}
image/svg+xml={{@@ browser_desktop @@}}
image/tiff={{@@ browser_desktop @@}}
image/vnd.djvu+multipage={{@@ browser_desktop @@}}
image/vnd.djvu={{@@ browser_desktop @@}}
image/webp={{@@ browser_desktop @@}}
text/html={{@@ geany_desktop @@}}
text/markdown={{@@ geany_desktop @@}}
text/plain={{@@ geany_desktop @@}}
video/mp4={{@@ mpv_desktop @@}}
video/x-matroska={{@@ mpv_desktop @@}};
x-scheme-handler/about={{@@ browser_desktop @@}}
x-scheme-handler/chrome={{@@ browser_desktop @@}}
x-scheme-handler/ftp={{@@ browser_desktop @@}}
x-scheme-handler/http={{@@ browser_desktop @@}}
x-scheme-handler/https={{@@ browser_desktop @@}}
x-scheme-handler/sftp={{@@ browser_desktop @@}}
x-scheme-handler/spotify={{@@ desktop_with_name('Spotify') @@}}
x-scheme-handler/unknown={{@@ browser_desktop @@}}

{%@@- if env['MACHINE'] == 'personal' @@%}

x-scheme-handler/mailto={{@@ desktop_with_name('Thunderbird') @@}}
x-scheme-handler/nordvpn=nordvpn.desktop
x-scheme-handler/tg={{@@ telegram_desktop @@}}
x-scheme-handler/tg={{@@ telegram_desktop @@}}
x-scheme-handler/tonsite={{@@ telegram_desktop @@}}
x-scheme-handler/fdm={{@@ desktop_with_name('Free Download Manager') @@}}

[Added Associations]
x-scheme-handler/tg={{@@ telegram_desktop @@}}
x-scheme-handler/tonsite={{@@ telegram_desktop @@}}

{%@@ elif env['MACHINE'] == 'work' @@%}

application/zip=xarchiver.desktop
x-scheme-handler/postman=Postman.desktop

{%@@ endif -@@%}
