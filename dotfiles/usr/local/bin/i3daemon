#!/usr/bin/env python3

import asyncio

from i3ipc.aio import Connection
from i3ipc import Event


def on_mode_change(i3, event):
    print(f'Mode changed to: {event.change}')


async def i3daemon():
    i3 = await Connection().connect()
    i3.on(Event.MODE, on_mode_change)
    await i3.main()


loop = asyncio.get_event_loop()
loop.run_until_complete(i3daemon())
loop.close()
