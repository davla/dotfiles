#!/usr/bin/env sh

# This script live-displays the {{@@ wm_name @@}} window tree of the workspace
# containing the currently focused window, following any updates as they occur.
#
# Updates to the window tree are detected via relevant "window"
# {{@@ wm_name @@}} IPC events, but can also be manually triggered by sending
# "tick" events with same payload as this script's first argument.
# This is necessary to respond to {{@@ wm_name @@}} container layout changes,
# which unfortunately are not covered by IPC events.
#
# {{@@ header() @@}}
#
# Arguments:
#   - $1: The payload that "tick" {{@@ wm_name @@}} IPC events should have in
#         order to trigger redrawing the window tree.

########################################
# Variables
########################################

TREE_CHILD_INDENT='  '

########################################
# Functions
########################################

# This function prints an {{@@ wm_name @@}} window tree depth-first. Each level
# down the tree is indented by an extra $TREE_CHILD_INDENT.
#
# It's defined as a subshell (with parentheses wrapping the body), rather than
# a regular command group, because it's recursive.
#
# Arguments:
#   - $1: The {{@@ wm_name @@}} window tree to be printed, in the JSON format
#         returned by {{@@ ipc_cmd @@}}.
#   - $2: The current node indent. Defaults to the empty string.
print_tree() (
    TREE="$1"
    CURRENT_INDENT="${2:-""}"

    NODE_NAME="$(echo "$TREE" | jq --raw-output '
            {
                "horizontal": " Horiz",
                "vertical": " Vert",
                "workspace": "󰨝",
            } as $labels
            | [
                $labels[.type]?,
                .name,
                $labels[.orientation]?,
                if .focused then "󰧀" else null end
            ]
            | map(values)
            | join(" ")')"
    printf '%s%s\n' "$CURRENT_INDENT" "$NODE_NAME"

    echo "$TREE" | jq --compact-output --unbuffered '.nodes? | arrays | .[]' \
        | while read -r CHILD; do
            print_tree "$CHILD" "${CURRENT_INDENT}${TREE_CHILD_INDENT}"
        done
)

########################################
# Process input
########################################

TICK_PAYLOAD="$1"
[ -z "$TICK_PAYLOAD" ] && {
    echo 2>&1 'Error: missing payload for "tick" {{@@ wm_name @@}} IPC events!'
    exit 63
}

########################################
# Main
########################################

JQ_EVENT_FILTER="$(printf '
select(
    .first?
    or .payload? == "%s"
    or IN("close", "floating", "focus", "fullscreen_mode", "move", "title"; .change?)
) | ""' "$TICK_PAYLOAD")"

{{@@ ipc_cmd @@}} --monitor --type SUBSCRIBE '["window", "tick"]' \
    | jq --raw-output --unbuffered "$JQ_EVENT_FILTER" \
    | while read -r _; do
        FOCUSED_WORKSPACE="$({{@@ ipc_cmd @@}} --type GET_TREE \
            | jq '.. | select(.type? == "workspace" and any(..; .focused?))')"
        print_tree "$FOCUSED_WORKSPACE"
    done
