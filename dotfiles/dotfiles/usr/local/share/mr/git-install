# This myrepos config file exports shell utility functions to work with
# package installation from git source code.

[DEFAULT]
updateWithResult =
    mr --directory "$MR_REPO" update 2> /dev/null \
        | grep 'up to date' > /dev/null 2>&1
upgrade =
    mr updateWithResult > /dev/null 2>&1 || mr --directory "$MR_REPO" install
