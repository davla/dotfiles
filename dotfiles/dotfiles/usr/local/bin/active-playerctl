#!/usr/bin/env sh

# This script wraps `playerctl` to allow it to operate on the currently active
# player(s)
#
# Arguments:
# - $@: Arguments forwarded to playerctl

########################################
# Input processing
########################################

# If an explicit player is passed as an argument, just call playerctl
case "$*" in
    '*--player*')
        playerctl "$@"
        exit
        ;;
esac

########################################
# Get active players
########################################

ACTIVE_PLAYERS="$(playerctl status --all-players \
    --format '{{playerName}} +++ {{status}}' | grep 'Playing' \
    | cut --delimiter '+++' --fields 1)"

########################################
# Execute playerctl
########################################

# If there's no active player, fallback to playerctl behavior with no specified
# player
if [ -z "$ACTIVE_PLAYERS" ]; then
    playerctl "$@"
else
    echo "$ACTIVE_PLAYERS" | xargs -I '{}' playerctl --player='{}' "$@"
fi
